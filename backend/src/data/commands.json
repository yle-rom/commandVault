      "category": "git",
      "description": "Record staged changes to the repository with a message describing what changed.",
      "usefulCommands": [
        {
          "cmd": "git commit -m \"message\"",
          "note": "commit with inline message"
        },
        {
          "cmd": "git commit --amend",
          "note": "modify the last commit"
        },
        {
          "cmd": "git commit -a -m \"message\"",
          "note": "stage all tracked files and commit"
        }
      ],
      "tags": [
        "git",
        "version-control"
      ]
    },
    {
      "id": "git-log",
      "name": "git log",
      "category": "git",
      "description": "Show commit history for the repository.",
      "usefulCommands": [
        {
          "cmd": "git log --oneline",
          "note": "compact one line per commit"
        },
        {
          "cmd": "git log --oneline --graph",
          "note": "visual branch graph"
        },
        {
          "cmd": "git log -p",
          "note": "show diff for each commit"
        },
        {
          "cmd": "git log --author=\"name\"",
          "note": "filter by author"
        }
      ],
      "tags": [
        "git",
        "version-control",
        "history"
      ]
    },
    {
      "id": "git-stash",
      "name": "git stash",
      "category": "git",
      "description": "Temporarily shelve changes so you can switch context without committing.",
      "usefulCommands": [
        {
          "cmd": "git stash",
          "note": "stash current changes"
        },
        {
          "cmd": "git stash pop",
          "note": "apply last stash and remove it"
        },
        {
          "cmd": "git stash list",
          "note": "list all stashes"
        },
        {
          "cmd": "git stash drop",
          "note": "delete last stash without applying"
        }
      ],
      "tags": [
        "git",
        "version-control"
      ]
    },
    {
      "id": "git-reset",
      "name": "git reset",
      "category": "git",
      "description": "Undo commits or unstage files. Use with caution on shared branches.",
      "usefulCommands": [
        {
          "cmd": "git reset HEAD~1",
          "note": "undo last commit, keep changes staged"
        },
        {
          "cmd": "git reset --hard HEAD~1",
          "note": "undo last commit, discard changes"
        },
        {
          "cmd": "git reset HEAD file.txt",
          "note": "unstage a specific file"
        }
      ],
      "tags": [
        "git",
        "version-control",
        "undo"
      ]
    },
