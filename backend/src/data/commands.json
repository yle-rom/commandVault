{
  "commands": [
    {
      "id": "ls",
      "name": "ls",
      "category": "filesystem",
      "description": "List directory contents. Shows files and directories in the current or specified directory.",
      "usefulCommands": [
        {
          "cmd": "ls -la",
          "note": "long format, show hidden files"
        },
        {
          "cmd": "ls -lh",
          "note": "human readable file sizes"
        },
        {
          "cmd": "ls -lt",
          "note": "sort by modification time"
        },
        {
          "cmd": "ls -R",
          "note": "list recursively"
        }
      ],
      "tags": [
        "filesystem",
        "navigation"
      ]
    },
    {
      "id": "find",
      "name": "find",
      "category": "filesystem",
      "description": "Search for files and directories in a directory hierarchy.",
      "usefulCommands": [
        {
          "cmd": "find . -name '*.ts'",
          "note": "find all TypeScript files"
        },
        {
          "cmd": "find . -type d",
          "note": "find directories only"
        },
        {
          "cmd": "find . -mtime -7",
          "note": "files modified in last 7 days"
        },
        {
          "cmd": "find . -size +100M",
          "note": "files larger than 100MB"
        }
      ],
      "tags": [
        "filesystem",
        "search"
      ]
    },
    {
      "id": "du",
      "name": "du",
      "category": "filesystem",
      "description": "Estimate file and directory space usage.",
      "usefulCommands": [
        {
          "cmd": "du -sh *",
          "note": "size of each item in current directory"
        },
        {
          "cmd": "du -sh .",
          "note": "total size of current directory"
        },
        {
          "cmd": "du -h --max-depth=1",
          "note": "one level deep with human readable sizes"
        }
      ],
      "tags": [
        "filesystem",
        "disk"
      ]
    },
    {
      "id": "git-commit",
